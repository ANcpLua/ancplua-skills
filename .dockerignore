# ═══════════════════════════════════════════════════════════════════════════════
# .dockerignore for ancplua-skills
# Excludes files from Docker build context
# ═══════════════════════════════════════════════════════════════════════════════

# Git
.git/
.gitignore
.gitattributes

# GitHub
.github/

# IDE and editor
.idea/
.vs/
.vscode/
**/*.DotSettings
**/*.user
**/*.suo

# Build outputs (not source files)
**/bin/
**/obj/
**/out/

# Nuke temp files
.nuke/temp/
.tmp/

# Documentation (not needed for build)
*.md
!skills/templates/*.md

# Test artifacts
TestResults/
coverage*/

# OS files
.DS_Store
Thumbs.db

# Environment and secrets
.env
.env.*
*.pem
*.key
secrets/

# Docker files (prevent recursion)
docker-compose*.yml
Dockerfile*
.dockerignore

# Other
*.log
npm-debug.log*
